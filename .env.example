# Duffel API
DUFFEL_API_TOKEN=duffel_test_your_token_here

# SerpApi (Google Flights) — mock=true면 불필요
SERPAPI_API_KEY=your_serpapi_key_here

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/flydeal
SPRING_DATASOURCE_USERNAME=flydeal
SPRING_DATASOURCE_PASSWORD=flydeal

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# Server
SERVER_PORT=8081
