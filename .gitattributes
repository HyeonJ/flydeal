# 텍스트 파일은 git에 LF로 저장, checkout 시 OS에 맞게 변환
* text=auto

# Java / Spring Boot
*.java text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.sql text eol=lf

# Frontend
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.vue text eol=lf
*.svelte text eol=lf

# Config / Script
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.toml text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Binary (변환하지 않음)
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
